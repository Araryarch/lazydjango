<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Django App{% endblock %}</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; margin: 0; padding: 0; background-color: #f5f5f5; }
        nav { background-color: #24292e; padding: 1rem; }
        nav a { color: white; text-decoration: none; margin-right: 1rem; }
        nav a:hover { text-decoration: underline; }
        .container { max-width: 800px; margin: 2rem auto; padding: 0 1rem; }
        .card { background: white; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); padding: 1.5rem; }
        h1, h2 { color: #24292e; margin-top: 0; }
        label { display: block; margin-bottom: 0.5rem; font-weight: 500; color: #24292e; }
        input, select, textarea { width: 100%; padding: 0.5rem; margin-bottom: 1rem; border: 1px solid #ddd; border-radius: 4px; box-sizing: border-box; font-size: 1rem; }
        input:focus, select:focus, textarea:focus { outline: none; border-color: #0366d6; }
        button, .btn { display: inline-block; padding: 0.5rem 1rem; background-color: #0366d6; color: white; border: none; border-radius: 4px; cursor: pointer; text-decoration: none; font-size: 1rem; }
        button:hover, .btn:hover { background-color: #0256b9; }
        .btn-secondary { background-color: #6a737d; }
        .btn-secondary:hover { background-color: #586069; }
        .error { color: #d73a49; font-size: 0.875rem; }
        .form-group { margin-bottom: 1rem; }
    </style>
    {% block extra_css %}{% endblock %}
</head>
<body>
    <nav>
        <div class="container" style="margin: 0; max-width: none; padding: 0;">
            <a href="/">Django App</a>
            <a href="/admin/" style="float: right;">Admin</a>
        </div>
    </nav>

    <div class="container">
        {% block content %}{% endblock %}
    </div>

    {% block extra_js %}{% endblock %}
</body>
</html>
